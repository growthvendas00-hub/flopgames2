# Copie este arquivo para .env e preencha os valores
# Na Vercel: adicione como Environment Variables no painel

# Chave da API BravoPay (obrigatório)
BRAVOPAY_API_KEY=bp_live_xxxxx

# Seu número de WhatsApp com DDI (opcional — aparece no botão da página de obrigado)
# Formato: 5511999999999
WHATSAPP_NUMBER=5511999999999

# Porta local (opcional — padrão 3002)
PORT=3002
